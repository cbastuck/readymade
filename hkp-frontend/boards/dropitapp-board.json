{
  "boardName": "DropApp",
  "facade": {
    "layout": "single",
    "panels": [
      {
        "id": "receive",
        "layout": {
          "direction": "column",
          "padding": 24,
          "gap": 20,
          "align": "center",
          "justify": "center",
          "fill": true,
          "items": [
            {
              "type": "qr-code",
              "caption": "Scan with your phone to send a file",
              "source": { "serviceUuid": "qr-code-svc", "path": "url" }
            },
            {
              "type": "text-input",
              "label": "Save folder",
              "placeholder": "/tmp/dropitapp",
              "submitLabel": "Set",
              "action": {
                "serviceUuid": "filesystem-svc",
                "configure": { "path": "$$input" }
              }
            }
          ]
        }
      }
    ]
  },
  "runtimes": [
    {
      "id": "ui",
      "name": "UI",
      "type": "browser",
      "state": { "wrapServices": false, "minimized": false }
    },
    {
      "id": "upload-server",
      "name": "Upload Server",
      "type": "rest",
      "url": "hkp://remotes/meander-cpp"
    }
  ],
  "services": {
    "ui": [
      {
        "uuid": "phone-board-svc",
        "serviceId": "sub-service",
        "serviceName": "Phone Board",
        "state": {
          "mode": "source",
          "boardName": "AirDrop Phone",
          "runtimeId": "phone-ui",
          "runtimeName": "Phone UI",
          "runtimeType": "browser",
          "facade": {
            "layout": "single",
            "panels": [
              {
                "id": "send",
                "layout": {
                  "type": "file-pick",
                  "label": "Drop a file to send",
                  "accept": "*/*",
                  "progressServiceUuid": "chunked-file-provider-svc",
                  "action": {
                    "serviceUuid": "image-picker-svc"
                  }
                }
              }
            ]
          },
          "pipeline": [
            {
              "instanceId": "image-picker-svc",
              "serviceId": "hookup.to/service/image-picker",
              "serviceName": "Image Picker"
            },
            {
              "instanceId": "chunked-file-provider-svc",
              "serviceId": "hookup.to/service/chunked-file-provider",
              "serviceName": "Chunked File Provider"
            },
            {
              "instanceId": "http-uploader-svc",
              "serviceId": "hookup.to/service/http-uploader",
              "serviceName": "HTTP Uploader",
              "state": { "url": "HKP_RUNTIME_URL/runtimes/upload-server" }
            }
          ]
        }
      },
      {
        "uuid": "upload-token-injector-svc",
        "serviceId": "hookup.to/service/http-uploader-token-injector",
        "serviceName": "HTTP Uploader Token Injector"
      },
      {
        "uuid": "lz-compress-svc",
        "serviceId": "hookup.to/service/lz-compress",
        "serviceName": "LZ Compress"
      },
      {
        "uuid": "url-builder-svc",
        "serviceId": "hookup.to/service/map",
        "serviceName": "URL Builder",
        "state": {
          "template": {
            "=": "concat('HKP_WEBAPP_URL/playground/dropitapp?fromLink=', params)"
          },
          "mode": "replace"
        }
      },
      {
        "uuid": "qr-code-svc",
        "serviceId": "hookup.to/service/qr-code",
        "serviceName": "QR Code"
      }
    ],
    "upload-server": [
      {
        "uuid": "filesystem-svc",
        "serviceId": "filesystem",
        "serviceName": "Filesystem",
        "state": {
          "path": "/tmp/dropitapp",
          "operation": "write"
        }
      }
    ]
  }
}
